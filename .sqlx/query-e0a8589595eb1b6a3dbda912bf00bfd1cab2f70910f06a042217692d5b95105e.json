  "query": "\n            SELECT\n              r.id,\n              r.report_type,\n              r.payload as \"payload!: Json<serde_json::Value>\",\n              r.actor_player_id,\n              r.actor_village_id,\n              r.target_player_id,\n              r.target_village_id,\n              r.created_at,\n              rr.read_at\n            FROM rm_reports r\n            JOIN rm_report_reads rr ON rr.report_id = r.id\n            WHERE r.id = $1 AND rr.player_id = $2\n            ",
